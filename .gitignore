# Laravel specific
/vendor/
/node_modules/
npm-debug.log
yarn-error.log

# Environment files
.env
.env.backup
.env.production

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Laravel storage (entire tree — logs, cache, sessions, uploads, keys; ensure dirs exist on deploy)
/storage/

# Bootstrap cache
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# Public storage
/public/storage
/public/hot

# Database
*.sqlite
*.sqlite-journal

# Compiled assets
/public/css/
/public/js/
/public/mix-manifest.json

# Testing
/.phpunit.cache
.phpunit.result.cache
coverage/

# Build files
/build/
/dist/

# Composer
composer.phar

# Package manager lock files (optional - uncomment if needed)
# package-lock.json
# yarn.lock

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Backup files and archives
*.bak
*.backup
*.zip
*.tar
*.tar.gz
*.7z
*~

# Python (bytecode, venvs, and sources — use !path/to/script.py to allow one file)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.py

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

